# Copy this file to .env.local for local development, and add the same
# variable in your Vercel project (Settings -> Environment Variables) for
# production/preview deployments.
#
# This key is used ONLY on the server (in app/api/chat/route.js). It is
# never sent to the browser, so it's safe to keep secret here.

# Get a key from https://console.anthropic.com (Settings -> API Keys).
# There is no default/shared value — you must generate your own.
ANTHROPIC_API_KEY=sk-ant-api03-REPLACE-WITH-YOUR-OWN-KEY
